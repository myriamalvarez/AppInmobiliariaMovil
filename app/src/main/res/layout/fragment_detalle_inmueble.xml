<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_teal"
    android:fillViewport="true"
    tools:context=".ui.inmuebles.DetalleInmuebleFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Título -->
        <TextView
            android:id="@+id/tvTituloDetalle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_detalle_inmueble"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/primary_purple_dark"
            android:layout_marginBottom="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Card con imagen y datos -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardDetalleInmueble"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/background_white"
            app:layout_constraintTop_toBottomOf="@id/tvTituloDetalle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Imagen del inmueble -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/ivDetalleInmueble"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/casa"
                        android:contentDescription="@string/imagen_inmueble"/>
                </androidx.cardview.widget.CardView>

                <!-- Grid con información -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <!-- Fila 1: Código y Ambientes -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_codigo_inmueble"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"/>

                            <TextView
                                android:id="@+id/tvCodigoDetalle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="503"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary_purple_dark"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_ambientes"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"/>

                            <TextView
                                android:id="@+id/tvAmbientesDetalle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Fila 2: Dirección y Precio -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_direccion"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"/>

                            <TextView
                                android:id="@+id/tvDireccionDetalle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Salta 325"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_precio"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"/>

                            <TextView
                                android:id="@+id/tvPrecioDetalle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$17000.0"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary_purple_dark"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Fila 3: Uso y Estado -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_uso"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"/>

                            <TextView
                                android:id="@+id/tvUsoDetalle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="particular"
                                android:textSize="16sp"
                                android:textColor="@color/text_primary"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp"
                            android:gravity="end">

                            <TextView
                                android:id="@+id/tvEstadoDetalle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="☑️ Disponible"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/disponible"
                                android:background="@drawable/badge_disponible"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="6dp"
                                android:paddingBottom="6dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Fila 4: Tipo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_tipo"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                        <TextView
                            android:id="@+id/tvTipoDetalle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Casa"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Switch para habilitar/deshabilitar -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSwitch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/background_white"
            app:layout_constraintTop_toBottomOf="@id/cardDetalleInmueble"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Disponibilidad del inmueble"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchDisponibilidad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/background_white"
                    app:trackTint="@color/disponible"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>



</ScrollView>