<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_white"
    tools:context=".ui.perfil.PerfilFragment">

    <!-- Header con gradiente turquesa -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:background="@drawable/gradient_teal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Foto de perfil -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardFotoPerfil"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="50dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/background_white"
        app:layout_constraintTop_toTopOf="@id/headerBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivFoto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/img_profe"
            android:scaleType="centerCrop"
            android:contentDescription="@string/foto_perfil"/>
    </androidx.cardview.widget.CardView>

    <!-- Nombre del propietario -->
    <TextView
        android:id="@+id/tvNombrePerfil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Luis Mercado"
        android:textColor="@color/text_white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/cardFotoPerfil"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ScrollView con la información del perfil -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card principal con información -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/background_white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Título Perfil -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/titulo_perfil"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_purple_dark"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/tvMensaje"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="8dp"/>

                    <!-- Campo: DNI -->
                    <TextView
                        android:id="@+id/tvDni"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_dni"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:id="@+id/etDni"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="17171780"
                        android:textSize="18sp"
                        android:textColor="@color/text_primary"
                        android:padding="12dp"
                        android:background="@drawable/bg_perfil"
                        android:layout_marginBottom="12dp"/>

                    <!-- Campo: Nombre -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_nombre"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"/>

                    <EditText
                        android:id="@+id/etNombre"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_perfil"
                        android:text="Luis Javier"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:enabled="false"
                        android:layout_marginBottom="12dp"/>

                    <!-- Campo: Apellido -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_apellido"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"/>

                    <EditText
                        android:id="@+id/etApellido"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_perfil"
                        android:text="Rodriguez"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:enabled="false"
                        android:layout_marginBottom="12dp"/>

                    <!-- Campo: Email -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_email"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"/>

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_perfil"
                        android:inputType="textEmailAddress"
                        android:text="luisprofessor@gmail.com"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:enabled="false"
                        android:layout_marginBottom="12dp"/>

                    <!-- Campo: Contraseña (solo mostrar asteriscos) -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_password"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_perfil"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="••••••••"
                            android:textSize="20sp"
                            android:textColor="@color/text_primary"/>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_lock_idle_lock"
                            android:contentDescription="@string/icono_password"
                            app:tint="@color/text_secondary"/>
                    </LinearLayout>

                    <!-- Campo: Teléfono -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_telefono"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"/>

                    <EditText
                        android:id="@+id/etTelefono"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_perfil"
                        android:inputType="phone"
                        android:text="1125254141"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:enabled="false"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botones -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <!-- Botón Editar/Guardar -->
                <Button
                    android:id="@+id/btnEditar"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/btn_editar"
                    android:textStyle="bold"
                    android:textColor="@color/text_white"
                    android:textSize="16sp"
                    android:backgroundTint="@color/button_secondary"
                    app:cornerRadius="28dp"
                    android:elevation="2dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Botón Cambiar Contraseña -->
                <Button
                    android:id="@+id/btnCambiarPassword"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/btn_cambiar_password_short"
                    android:textStyle="bold"
                    android:textColor="@color/text_white"
                    android:textSize="16sp"
                    android:backgroundTint="@color/primary_purple"
                    app:cornerRadius="28dp"
                    android:elevation="2dp"
                    android:drawableStart="@android:drawable/ic_lock_idle_lock"
                    android:drawableTint="@color/text_white"
                    android:drawablePadding="8dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"/>

            </LinearLayout>

        </LinearLayout>


    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>