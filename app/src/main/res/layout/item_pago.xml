<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/disponible">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Primera línea: Código de pago -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_codigo_pago"
            android:textSize="11sp"
            android:textColor="@color/text_white"
            android:alpha="0.8"/>

        <TextView
            android:id="@+id/tvCodigoPago"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="300"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            android:layout_marginBottom="8dp"/>

        <!-- Segunda línea: Número de pago -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_numero_pago"
            android:textSize="11sp"
            android:textColor="@color/text_white"
            android:alpha="0.8"/>

        <TextView
            android:id="@+id/tvNumeroPago"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1"
            android:textSize="16sp"
            android:textColor="@color/text_white"
            android:layout_marginBottom="8dp"/>

        <!-- Tercera línea: Código de contrato -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_codigo_contrato"
            android:textSize="11sp"
            android:textColor="@color/text_white"
            android:alpha="0.8"/>

        <TextView
            android:id="@+id/tvCodigoContratoItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="701"
            android:textSize="16sp"
            android:textColor="@color/text_white"
            android:layout_marginBottom="8dp"/>

        <!-- Cuarta línea: Importe -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_importe"
            android:textSize="11sp"
            android:textColor="@color/text_white"
            android:alpha="0.8"/>

        <TextView
            android:id="@+id/tvImportePago"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$17000.0"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            android:layout_marginBottom="8dp"/>

        <!-- Quinta línea: Fecha de pago -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_fecha_pago"
            android:textSize="11sp"
            android:textColor="@color/text_white"
            android:alpha="0.8"/>

        <TextView
            android:id="@+id/tvFechaPago"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10/02/2020"
            android:textSize="16sp"
            android:textColor="@color/text_white"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>