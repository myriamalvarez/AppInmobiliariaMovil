<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/background_white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Imagen del inmueble -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardImagen"
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/ivInmueble"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/casa"
                android:contentDescription="@string/imagen_inmueble"/>
        </androidx.cardview.widget.CardView>

        <!-- Información del inmueble -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="@id/cardImagen"
            app:layout_constraintBottom_toBottomOf="@id/cardImagen"
            app:layout_constraintStart_toEndOf="@id/cardImagen"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Dirección -->
            <TextView
                android:id="@+id/tvDireccionItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Salta 325"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Precio -->
            <TextView
                android:id="@+id/tvPrecioItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="$17000.0"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/primary_purple_dark"/>

            <!-- Ambientes y tipo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvAmbientesItem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 amb"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:drawableStart="@drawable/ic_room"
                    android:drawablePadding="4dp"
                    android:drawableTint="@color/text_secondary"/>

                <TextView
                    android:id="@+id/tvTipoItem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Casa"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:drawableStart="@drawable/ic_home_1"
                    android:drawablePadding="4dp"
                    android:drawableTint="@color/text_secondary"/>

                <TextView
                    android:id="@+id/tvUsoItem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Residencial"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:drawableStart="@drawable/ic_uso"
                    android:drawablePadding="4dp"
                    android:drawableTint="@color/text_secondary"/>
            </LinearLayout>

            <!-- Estado (Disponible/No disponible) -->
            <TextView
                android:id="@+id/tvEstadoItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Disponible"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/disponible"
                android:background="@drawable/badge_disponible"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>