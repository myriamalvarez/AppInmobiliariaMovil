<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/card_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Imagen -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardImagen"
            android:layout_width="90dp"
            android:layout_height="90dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/ivInmueble"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/casa"
                android:contentDescription="@string/imagen_inmueble"/>
        </androidx.cardview.widget.CardView>

        <!-- Contenedor texto -->
        <LinearLayout
            android:id="@+id/layoutInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="@id/cardImagen"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/cardImagen"
            app:layout_constraintBottom_toBottomOf="@id/cardImagen">

            <!-- Dirección -->
            <TextView
                android:id="@+id/tvDireccionItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Salta 325"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Tipo -->
            <TextView
                android:id="@+id/tvTipoItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Casa"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"/>

            <!-- Ambientes -->
            <TextView
                android:id="@+id/tvAmbientesItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="3 ambientes"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>

            <!-- Precio -->
            <TextView
                android:id="@+id/tvPrecioItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="$17000"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_purple_dark"/>

            <!-- Estado -->
            <TextView
                android:id="@+id/tvEstadoItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ Disponible"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>