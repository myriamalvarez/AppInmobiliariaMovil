<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/background_teal"
    android:fillViewport="true"
    tools:context=".ui.perfil.CambiarClaveFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Icono de candado -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardIcono"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/primary_purple"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_lock_idle_lock"
                android:contentDescription="@string/icono_cambiar_password"
                app:tint="@color/text_white"/>
        </androidx.cardview.widget.CardView>

        <!-- Título -->
        <TextView
            android:id="@+id/tvTituloCambiarPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/titulo_cambiar_password"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/primary_purple_dark"
            app:layout_constraintTop_toBottomOf="@id/cardIcono"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Subtítulo -->
        <TextView
            android:id="@+id/tvSubtitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/subtitulo_cambiar_password"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:textAlignment="center"
            app:layout_constraintTop_toBottomOf="@id/tvTituloCambiarPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Card contenedor -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFormulario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/background_white"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Label contraseña actual -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_password_actual"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp"/>

                <!-- Campo contraseña actual -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPasswordActual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="@color/primary_purple_light"
                    app:boxStrokeColor="@color/primary_purple"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                    app:startIconTint="@color/primary_purple"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/primary_purple"
                    app:hintTextColor="@color/primary_purple">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPasswordActual"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_password_actual"
                        android:inputType="textPassword"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Label contraseña nueva -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_password_nueva"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp"/>

                <!-- Campo contraseña nueva -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPasswordNueva"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="@color/primary_purple_light"
                    app:boxStrokeColor="@color/primary_purple"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                    app:startIconTint="@color/disponible"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/primary_purple"
                    app:hintTextColor="@color/primary_purple"
                    app:helperText="@string/helper_password"
                    app:helperTextTextColor="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPasswordNueva"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_password_nueva"
                        android:inputType="textPassword"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"/>
                </com.google.android.material.textfield.TextInputLayout>



                <!-- Botón confirmar cambio -->
                <Button
                    android:id="@+id/btnCambiarPassword"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/btn_cambiar_password"
                    android:textStyle="bold"
                    android:textColor="@color/text_white"
                    android:textSize="16sp"
                    android:backgroundTint="@color/button_primary"
                    app:cornerRadius="28dp"
                    android:elevation="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvMensaje"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/cardFormulario"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>